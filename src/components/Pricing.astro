---
import pricing from '../data/pricing.json';
---

<section id="pricing" class="pricing">
  <div class="container">
    <div class="section-header">
      <h2>简单透明的定价</h2>
      <p>选择适合你团队的方案，随时升级或降级。</p>
    </div>
    <div class="pricing-grid">
      {pricing.map((plan: { name: string; price: string; period: string; description: string; features: string[]; cta: string; highlighted: boolean }) => (
        <div class:list={["pricing-card", { highlighted: plan.highlighted }]}>
          {plan.highlighted && <span class="badge">最受欢迎</span>}
          <h3>{plan.name}</h3>
          <div class="price">
            <span class="amount">{plan.price}</span>
            <span class="period">{plan.period}</span>
          </div>
          <p class="plan-desc">{plan.description}</p>
          <ul class="plan-features">
            {plan.features.map((f: string) => (
              <li>{f}</li>
            ))}
          </ul>
          <a href="#" class:list={["btn", { "btn-primary": plan.highlighted, "btn-outline": !plan.highlighted }]}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing {
    padding: 100px 0;
    background: var(--color-bg-alt);
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-header h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .section-header p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  .pricing-card {
    background: white;
    border-radius: 12px;
    padding: 36px;
    border: 1px solid var(--color-border);
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .pricing-card.highlighted {
    border-color: var(--color-primary);
    box-shadow: 0 8px 30px rgba(99, 102, 241, 0.15);
    transform: scale(1.03);
  }

  .badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: white;
    padding: 4px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .price {
    margin-bottom: 8px;
  }

  .amount {
    font-size: 2.5rem;
    font-weight: 800;
  }

  .period {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .plan-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 24px;
  }

  .plan-features {
    list-style: none;
    margin-bottom: 32px;
    flex: 1;
  }

  .plan-features li {
    padding: 8px 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
  }

  .plan-features li::before {
    content: "✓ ";
    color: var(--color-primary);
    font-weight: 600;
  }

  .btn {
    display: block;
    text-align: center;
    padding: 12px 24px;
    border-radius: var(--radius);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
  }

  .btn-outline {
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-outline:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .pricing-card.highlighted {
      transform: none;
    }
  }
</style>
