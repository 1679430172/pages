---
import testimonials from '../data/testimonials.json';
---

<section id="testimonials" class="testimonials">
  <div class="container">
    <div class="section-header">
      <h2>深受团队信赖</h2>
      <p>看看其他团队如何使用 FlowSync 提升效率。</p>
    </div>
    <div class="testimonials-grid">
      {testimonials.map((t: { name: string; role: string; content: string; avatar: string }) => (
        <div class="testimonial-card">
          <p class="quote">"{t.content}"</p>
          <div class="author">
            <div class="avatar">{t.avatar}</div>
            <div>
              <div class="name">{t.name}</div>
              <div class="role">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 100px 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-header h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .section-header p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .testimonial-card {
    padding: 32px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-alt);
  }

  .quote {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 24px;
  }

  .author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .name {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .role {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
